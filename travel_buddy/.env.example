# ===== Travel Buddy — пример .env =====
# Скопируй этот файл в .env (в той же папке, что и manage.py)
# и заполни своими значениями. Файл .env уже в .gitignore.
# ВНИМАНИЕ: в .env.example храним только заглушки, реальные пароли — в .env!

# Секретный ключ Django (для prod — сгенерируй новый)
SECRET_KEY=django-insecure-your-secret-key-here

# ===== Gmail SMTP =====
# 1. Включи 2FA: https://myaccount.google.com/security
# 2. Сгенерируй App Password: https://myaccount.google.com/apppasswords
#    (выбери "Mail" → "Other" → дай любое имя)
# 3. 16-символьный пароль вставь без пробелов в .env
EMAIL_HOST_USER=your_account@gmail.com
EMAIL_HOST_PASSWORD=abcdefghijklmnop

# Опционально (значения по умолчанию подойдут для Gmail)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=Travel Buddy <your_account@gmail.com>
